//@version=6
indicator("SMS Pro XAUUSD v7", shorttitle="SMS-XAU v7", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=200)

// ============================================================================
// SMS PRO XAUUSD v7 - UPGRADE COMPLETO
// ============================================================================
// CAMBIOS vs v6:
// ✅ RSI Confluencia CORREGIDA (ya no regala +1 siempre)
// ✅ Cooldown inteligente: 20 barras + anti-flip
// ✅ Volume Confirmation (e3v / Range Volume inspired)
// ✅ SMC LuxAlgo: Premium/Discount dinámico, Inducement, Breaker Blocks
// ✅ Session Volume Profile (VWAP + desviaciones)
// ✅ Alertas mejoradas: solo señales de alta calidad
// ✅ Filtro anti-ruido: No señales contra MTF dominante
// ✅ Confluence rebalanceada: 13 factores, mínimo 5 recomendado
// ============================================================================

// ============================================================================
// INPUTS
// ============================================================================

// --- EMAs ---
emaFastLen     = input.int(9, "EMA Rapida", minval=1, group="EMAs")
emaSlowLen     = input.int(21, "EMA Lenta", minval=1, group="EMAs")
ema200Len      = input.int(200, "EMA 200", minval=50, group="EMAs")
showEMA200     = input.bool(true, "Mostrar EMA 200", group="EMAs")

// --- Market Structure ---
swingLen       = input.int(5, "Swing Lookback", minval=2, maxval=20, group="Structure")
showBOS        = input.bool(true, "Mostrar BOS", group="Structure")
showCHOCH      = input.bool(true, "Mostrar CHoCH", group="Structure")

// --- Order Blocks ---
showOB         = input.bool(true, "Mostrar Order Blocks", group="Order Blocks")
maxOB          = input.int(3, "Max OB visibles", minval=1, maxval=10, group="Order Blocks")
obMinStrength  = input.float(0.5, "OB Fuerza minima (x ATR)", minval=0.3, maxval=1.5, step=0.1, group="Order Blocks", tooltip="Body de vela OB debe ser > X veces ATR")

// --- Breaker Blocks (SMC LuxAlgo) ---
showBreakerOB  = input.bool(true, "Mostrar Breaker Blocks", group="Breaker Blocks", tooltip="OB invalidado que se convierte en soporte/resistencia")
maxBreaker     = input.int(2, "Max Breaker visibles", minval=1, maxval=5, group="Breaker Blocks")

// --- FVG ---
showFVG        = input.bool(true, "Mostrar FVG", group="FVG")
fvgMinSize     = input.float(0.15, "Tamano minimo FVG %", minval=0.05, maxval=1.0, group="FVG")
maxFVG         = input.int(3, "Max FVG visibles", minval=1, maxval=10, group="FVG")
useFVGConf     = input.bool(true, "Usar FVG como Confluencia", group="FVG")

// --- Liquidez ---
showSweeps     = input.bool(true, "Mostrar Liquidity Sweeps", group="Liquidez")
showEQHL       = input.bool(false, "Mostrar Equal H/L", group="Liquidez")
eqhLookback    = input.int(15, "Lookback EQH/L", minval=5, maxval=50, group="Liquidez")
filterSweeps   = input.bool(true, "Filtrar Sweeps (solo en KZ)", group="Liquidez")
showInducement = input.bool(true, "Mostrar Inducement", group="Liquidez", tooltip="Detecta liquidez interna que instituciones buscan capturar antes de mover precio")

// --- Kill Zones ---
showKillZones  = input.bool(true, "Mostrar Kill Zones", group="Kill Zones")
onlyTradeKZ    = input.bool(false, "Solo senales en Kill Zone", group="Kill Zones")
showTokyoKZ    = input.bool(false, "Incluir Tokyo KZ (para JPY)", group="Kill Zones")

// --- Fibonacci / Premium-Discount ---
showFib        = input.bool(true, "Mostrar Fib 50%", group="Fibonacci")
fibLookback    = input.int(30, "Lookback", minval=10, maxval=100, group="Fibonacci")
showPDLevels   = input.bool(true, "Mostrar Premium/Discount Cuadrantes", group="Fibonacci", tooltip="Divide el rango en zonas: Deep Discount, Discount, Premium, Deep Premium")

// --- Senales ---
showSignals    = input.bool(true, "Mostrar Senales", group="Senales")
minConfluence  = input.int(5, "Minimo Confluencias", minval=3, maxval=11, group="Senales", tooltip="v7 tiene 13 confluencias. Minimo 5 recomendado para calidad")
showLabels     = input.bool(true, "Mostrar Labels SL/TP", group="Senales")
cooldownBars   = input.int(20, "Cooldown entre senales (barras)", minval=5, maxval=50, group="Senales", tooltip="v6 usaba 10 = muy poco. 20 barras = ~1.5h en M5")
requireMTFalign = input.bool(true, "Bloquear senales contra MTF", group="Senales", tooltip="CRITICO: No genera LONG si MTF es BEAR y viceversa")
minQualityScore = input.int(0, "Score minimo de calidad (0=off)", minval=0, maxval=3, group="Senales", tooltip="0=todas, 1=normal+, 2=strong+, 3=solo premium")

// --- ATR & Risk ---
atrLen         = input.int(14, "Periodo ATR", minval=5, maxval=50, group="ATR & Risk")
atrMult        = input.float(1.5, "Multiplicador SL", minval=0.5, maxval=3.0, group="ATR & Risk")
rrRatio        = input.float(2.0, "Ratio R:R", minval=1.0, maxval=5.0, group="ATR & Risk")
useOBforSL     = input.bool(true, "Usar OB para SL", group="ATR & Risk")

// --- RSI (Confluencia CORREGIDA) ---
useRSIConf     = input.bool(true, "Usar RSI como Confluencia", group="RSI Filter")
rsiLen         = input.int(14, "Periodo RSI", minval=5, maxval=21, group="RSI Filter")
rsiOB          = input.int(70, "Sobrecompra", minval=60, maxval=85, group="RSI Filter")
rsiOS          = input.int(30, "Sobreventa", minval=15, maxval=40, group="RSI Filter")

// --- MTF ---
useMTFConf     = input.bool(true, "Usar MTF como Confluencia", group="MTF")
mtfTF          = input.timeframe("30", "Temporalidad Superior", group="MTF")
mtfEmaFLen     = input.int(9, "EMA Rapida HTF", minval=1, group="MTF")
mtfEmaSLen     = input.int(21, "EMA Lenta HTF", minval=1, group="MTF")
showMTFEmas    = input.bool(false, "Mostrar EMAs HTF", group="MTF")

// --- Volume Confirmation (NUEVO - inspirado e3v/Range Volume) ---
useVolConf     = input.bool(true, "Usar Volumen como Confluencia", group="Volume")
volLen         = input.int(20, "Periodo promedio volumen", minval=5, maxval=50, group="Volume")
volMultiplier  = input.float(1.3, "Multiplicador vol. significativo", minval=1.0, maxval=3.0, step=0.1, group="Volume", tooltip="Volumen actual > X veces promedio = confirmacion")
showVolProfile = input.bool(true, "Mostrar VWAP Session", group="Volume", tooltip="VWAP de sesion con bandas de desviacion")
vwapDevMult    = input.float(1.0, "VWAP Desviacion", minval=0.5, maxval=3.0, step=0.25, group="Volume")
useVWAPConf    = input.bool(true, "Usar VWAP como Confluencia", group="Volume", tooltip="Suma +1 si precio en lado correcto del VWAP para la dirección")

// --- Momentum Quality ---
useMomQuality  = input.bool(true, "Evaluar Momentum", group="Momentum")
momRangeMult   = input.float(1.5, "Mult. Rango vs Promedio", minval=1.0, maxval=3.0, step=0.1, group="Momentum")
momCloseRatio  = input.float(0.7, "Cierre cerca extremo", minval=0.5, maxval=0.95, step=0.05, group="Momentum")
momAvgLen      = input.int(20, "Periodo promedio rango", minval=5, maxval=50, group="Momentum")

// --- BE Levels ---
showBELevels   = input.bool(true, "Mostrar BE 1:1", group="BE Levels")
beLevelExtend  = input.int(20, "Barras extension", minval=5, maxval=50, group="BE Levels")
showTP2Level   = input.bool(false, "Mostrar TP2 parcial", group="BE Levels")

// --- Spread ---
spreadPips     = input.float(3.0, "Spread ($)", minval=0.5, maxval=10.0, group="Spread")
addSpreadToSL  = input.bool(true, "Agregar spread al SL", group="Spread")
spreadBuffer   = input.float(1.0, "Buffer adicional ($)", minval=0.0, maxval=5.0, group="Spread")

// --- Alertas ---
enableAlerts   = input.bool(true, "Habilitar Alertas", group="Alertas")
alertOnSweeps  = input.bool(false, "Alertas Sweeps", group="Alertas")
alertOnCHoCH   = input.bool(true, "Alertas CHoCH", group="Alertas")
alertOnBOS     = input.bool(false, "Alertas BOS", group="Alertas")
alertMinConf   = input.int(5, "Min. confluencias para alerta", minval=3, maxval=11, group="Alertas", tooltip="Solo alerta si la señal tiene >= X confluencias")
alertOnlyKZ    = input.bool(true, "Solo alertar en Kill Zone", group="Alertas", tooltip="Reduce ruido: solo alerta cuando estás en sesión activa")
alertOnlyStrong = input.bool(false, "Solo alertar STRONG+", group="Alertas", tooltip="Solo manda alerta si momentum es STRONG o PREMIUM")

// --- Panel ---
showPanel      = input.bool(true, "Mostrar Panel Info", group="Visual")

// ============================================================================
// COLORES
// ============================================================================

bullColor      = color.rgb(0, 230, 118)
bearColor      = color.rgb(255, 82, 82)
bosColor       = color.rgb(0, 188, 212)
chochColor     = color.rgb(255, 152, 0)
obBullColor    = color.new(color.rgb(38, 166, 154), 80)
obBearColor    = color.new(color.rgb(239, 83, 80), 80)
fvgBullColor   = color.new(color.rgb(0, 150, 255), 80)
fvgBearColor   = color.new(color.rgb(255, 150, 0), 80)
breakerBullCol = color.new(color.rgb(0, 200, 255), 75)
breakerBearCol = color.new(color.rgb(255, 100, 200), 75)
vwapColor      = color.rgb(255, 235, 59)
// Premium/Discount ahora via Fib lines, no bgcolor solido

// ============================================================================
// CALCULOS BASE
// ============================================================================

emaFast  = ta.ema(close, emaFastLen)
emaSlow  = ta.ema(close, emaSlowLen)
ema200   = ta.ema(close, ema200Len)
atrValue = ta.atr(atrLen)
rsiValue = ta.rsi(close, rsiLen)

// --- MTF ---
mtfEmaFast  = request.security(syminfo.tickerid, mtfTF, ta.ema(close, mtfEmaFLen), lookahead=barmerge.lookahead_off)
mtfEmaSlow  = request.security(syminfo.tickerid, mtfTF, ta.ema(close, mtfEmaSLen), lookahead=barmerge.lookahead_off)
mtfClose    = request.security(syminfo.tickerid, mtfTF, close, lookahead=barmerge.lookahead_off)
mtfHigh     = request.security(syminfo.tickerid, mtfTF, high, lookahead=barmerge.lookahead_off)
mtfLow      = request.security(syminfo.tickerid, mtfTF, low, lookahead=barmerge.lookahead_off)
mtfRSI      = request.security(syminfo.tickerid, mtfTF, ta.rsi(close, rsiLen), lookahead=barmerge.lookahead_off)
mtfTrendUp  = mtfEmaFast > mtfEmaSlow and mtfClose > mtfEmaSlow
mtfTrendDn  = mtfEmaFast < mtfEmaSlow and mtfClose < mtfEmaSlow
mtfTrendName = mtfTrendUp ? "BULL" : mtfTrendDn ? "BEAR" : "MIX"

totalSpreadBuf = addSpreadToSL ? (spreadPips + spreadBuffer) : 0

trendUp    = emaFast > emaSlow
trendDown  = emaFast < emaSlow
htfTrendUp = close > ema200
htfTrendDn = close < ema200

bodySize   = math.abs(close - open)
candleRange = high - low
upperWick  = high - math.max(close, open)
lowerWick  = math.min(close, open) - low
isBullCandle = close > open
isBearCandle = close < open

// --- Momentum Quality ---
avgRange = ta.sma(high - low, momAvgLen)
isMomCandle = candleRange > avgRange * momRangeMult
bullCloseStr = candleRange > 0 ? (close - low) / candleRange : 0
bearCloseStr = candleRange > 0 ? (high - close) / candleRange : 0
isStrongBullClose = bullCloseStr >= momCloseRatio and isBullCandle
isStrongBearClose = bearCloseStr >= momCloseRatio and isBearCandle
isStrongBull = isMomCandle and isStrongBullClose
isStrongBear = isMomCandle and isStrongBearClose

// --- Volume Analysis (NUEVO - e3v / Range Volume inspired) ---
vol = volume
avgVol = ta.sma(vol, volLen)
isHighVol = vol > avgVol * volMultiplier
isLowVol = vol < avgVol * 0.5
// Volumen relativo (para scoring)
volRatio = avgVol > 0 ? vol / avgVol : 1.0
// Volume delta aproximado (close vs range)
vDelta = candleRange > 0 ? (close - low) / candleRange * 2 - 1 : 0  // -1 a +1
bullVolConf = isHighVol and vDelta > 0.3 and isBullCandle  // Alto volumen + delta positivo + vela alcista
bearVolConf = isHighVol and vDelta < -0.3 and isBearCandle // Alto volumen + delta negativo + vela bajista

// --- VWAP Session (Range Volume Profile simplificado) ---
var float vwapSum = 0.0
var float vwapVolSum = 0.0
var float vwapSqSum = 0.0
var bool newSession = false

// Detectar nueva sesion (reset a las 17:00 EST = 22:00 UTC para forex)
utcHourVwap = hour(time, "UTC")
newSession := (utcHourVwap == 22 and utcHourVwap[1] != 22) or (na(vwapSum))

if newSession
    vwapSum := 0.0
    vwapVolSum := 0.0
    vwapSqSum := 0.0

typicalPrice = (high + low + close) / 3
vwapSum := vwapSum + typicalPrice * vol
vwapVolSum := vwapVolSum + vol
vwapSqSum := vwapSqSum + typicalPrice * typicalPrice * vol

sessionVwap = vwapVolSum > 0 ? vwapSum / vwapVolSum : close
vwapVariance = vwapVolSum > 0 ? (vwapSqSum / vwapVolSum) - (sessionVwap * sessionVwap) : 0
vwapStdDev = math.sqrt(math.max(vwapVariance, 0))
vwapUpper = sessionVwap + vwapStdDev * vwapDevMult
vwapLower = sessionVwap - vwapStdDev * vwapDevMult

priceAboveVwap = close > sessionVwap
priceBelowVwap = close < sessionVwap
priceNearVwap = math.abs(close - sessionVwap) < atrValue * 0.3  // Cerca del VWAP = zona de valor

// ============================================================================
// KILL ZONES
// ============================================================================

utcHour = hour(time, "UTC")
estHour = (utcHour - 5 + 24) % 24

inTokyoKZ   = showTokyoKZ and (estHour >= 19 or estHour < 1)
inLondonKZ  = estHour >= 2 and estHour < 5
inNYKZ      = estHour >= 7 and estHour < 10
inNYOverlap = estHour >= 8 and estHour < 11
inAnyKZ     = inLondonKZ or inNYKZ or inNYOverlap or inTokyoKZ

// v7.1 FIX: Solo franja sutil en top/bottom del chart - transparencia 97
kzBgColor = showKillZones ? (inLondonKZ ? color.new(color.blue, 97) : inNYKZ or inNYOverlap ? color.new(color.green, 97) : inTokyoKZ ? color.new(color.purple, 97) : na) : na
bgcolor(kzBgColor)

kzName = inLondonKZ ? "LONDON" : inNYOverlap ? "NY-OVERLAP" : inNYKZ ? "NEW YORK" : inTokyoKZ ? "TOKYO" : "FUERA KZ"

// ============================================================================
// MARKET STRUCTURE
// ============================================================================

swingHigh = ta.pivothigh(high, swingLen, swingLen)
swingLow  = ta.pivotlow(low, swingLen, swingLen)

var float lastSH = na
var float lastSL = na
var float prevSH = na
var float prevSL = na
var int trendDir = 0

if not na(swingHigh)
    prevSH := lastSH
    lastSH := swingHigh
if not na(swingLow)
    prevSL := lastSL
    lastSL := swingLow

crossOverHigh  = ta.crossover(close, nz(lastSH, high))
crossUnderLow  = ta.crossunder(close, nz(lastSL, low))

bos_bull  = not na(lastSH) and crossOverHigh and trendDir == 1
bos_bear  = not na(lastSL) and crossUnderLow and trendDir == -1
choch_bull = not na(lastSH) and crossOverHigh and trendDir == -1
choch_bear = not na(lastSL) and crossUnderLow and trendDir == 1

if choch_bull or bos_bull
    trendDir := 1
if choch_bear or bos_bear
    trendDir := -1

bos_bull_c  = showBOS and bos_bull and barstate.isconfirmed
bos_bear_c  = showBOS and bos_bear and barstate.isconfirmed
choch_bull_c = showCHOCH and choch_bull and barstate.isconfirmed
choch_bear_c = showCHOCH and choch_bear and barstate.isconfirmed

// FIX: Variables confirmadas para confluencia (NO dependen de toggles de display)
bos_bull_conf  = bos_bull and barstate.isconfirmed
bos_bear_conf  = bos_bear and barstate.isconfirmed
choch_bull_conf = choch_bull and barstate.isconfirmed
choch_bear_conf = choch_bear and barstate.isconfirmed

if bos_bull_c
    label.new(bar_index, low, "BOS", style=label.style_label_up, color=bosColor, textcolor=color.white, size=size.tiny)
if bos_bear_c
    label.new(bar_index, high, "BOS", style=label.style_label_down, color=bosColor, textcolor=color.white, size=size.tiny)
if choch_bull_c
    label.new(bar_index, low, "CHoCH", style=label.style_label_up, color=chochColor, textcolor=color.white, size=size.small)
if choch_bear_c
    label.new(bar_index, high, "CHoCH", style=label.style_label_down, color=chochColor, textcolor=color.white, size=size.small)

// ============================================================================
// ORDER BLOCKS - CON ALMACENAMIENTO PARA SL
// ============================================================================

var array<box> bullOBBoxes    = array.new<box>()
var array<box> bearOBBoxes    = array.new<box>()
var array<float> bullOBTops   = array.new<float>()
var array<float> bullOBBottoms = array.new<float>()
var array<float> bearOBTops   = array.new<float>()
var array<float> bearOBBottoms = array.new<float>()

bullOB = isBearCandle[1] and isBullCandle and close > high[1] and (close - open) > atrValue * obMinStrength
bearOB = isBullCandle[1] and isBearCandle and close < low[1] and (open - close) > atrValue * obMinStrength

if showOB and bullOB and barstate.isconfirmed
    if array.size(bullOBBoxes) >= maxOB
        oldBox = array.shift(bullOBBoxes)
        box.delete(oldBox)
        array.shift(bullOBTops)
        array.shift(bullOBBottoms)
    newBox = box.new(bar_index - 1, high[1], bar_index + 30, low[1], bgcolor=obBullColor, border_color=bullColor, border_width=1)
    array.push(bullOBBoxes, newBox)
    array.push(bullOBTops, high[1])
    array.push(bullOBBottoms, low[1])

if showOB and bearOB and barstate.isconfirmed
    if array.size(bearOBBoxes) >= maxOB
        oldBox = array.shift(bearOBBoxes)
        box.delete(oldBox)
        array.shift(bearOBTops)
        array.shift(bearOBBottoms)
    newBox = box.new(bar_index - 1, high[1], bar_index + 30, low[1], bgcolor=obBearColor, border_color=bearColor, border_width=1)
    array.push(bearOBBoxes, newBox)
    array.push(bearOBTops, high[1])
    array.push(bearOBBottoms, low[1])

// ============================================================================
// BREAKER BLOCKS (SMC LuxAlgo concept)
// Un OB invalidado (mitigado) se convierte en Breaker Block
// ============================================================================

var array<box> bullBreakerBoxes = array.new<box>()
var array<box> bearBreakerBoxes = array.new<box>()
var array<float> bullBreakerTops = array.new<float>()
var array<float> bullBreakerBots = array.new<float>()
var array<float> bearBreakerTops = array.new<float>()
var array<float> bearBreakerBots = array.new<float>()

// Mitigar OB + crear Breaker
if array.size(bullOBBoxes) > 0
    for i = array.size(bullOBBoxes) - 1 to 0
        if i < array.size(bullOBBottoms) and close < array.get(bullOBBottoms, i)
            // Bull OB invalidado -> se convierte en Bearish Breaker (resistencia)
            if showBreakerOB and array.size(bearBreakerBoxes) < maxBreaker
                bTop = array.get(bullOBTops, i)
                bBot = array.get(bullOBBottoms, i)
                brkBox = box.new(bar_index, bTop, bar_index + 40, bBot, bgcolor=breakerBearCol, border_color=color.rgb(255, 100, 200), border_width=1, border_style=line.style_dashed)
                array.push(bearBreakerBoxes, brkBox)
                array.push(bearBreakerTops, bTop)
                array.push(bearBreakerBots, bBot)
            box.delete(array.get(bullOBBoxes, i))
            array.remove(bullOBBoxes, i)
            array.remove(bullOBTops, i)
            array.remove(bullOBBottoms, i)

if array.size(bearOBBoxes) > 0
    for i = array.size(bearOBBoxes) - 1 to 0
        if i < array.size(bearOBTops) and close > array.get(bearOBTops, i)
            // Bear OB invalidado -> se convierte en Bullish Breaker (soporte)
            if showBreakerOB and array.size(bullBreakerBoxes) < maxBreaker
                bTop = array.get(bearOBTops, i)
                bBot = array.get(bearOBBottoms, i)
                brkBox = box.new(bar_index, bTop, bar_index + 40, bBot, bgcolor=breakerBullCol, border_color=color.rgb(0, 200, 255), border_width=1, border_style=line.style_dashed)
                array.push(bullBreakerBoxes, brkBox)
                array.push(bullBreakerTops, bTop)
                array.push(bullBreakerBots, bBot)
            box.delete(array.get(bearOBBoxes, i))
            array.remove(bearOBBoxes, i)
            array.remove(bearOBTops, i)
            array.remove(bearOBBottoms, i)

// Mitigar Breaker Blocks
if array.size(bullBreakerBoxes) > 0
    for i = array.size(bullBreakerBoxes) - 1 to 0
        if i < array.size(bullBreakerBots) and close < array.get(bullBreakerBots, i)
            box.delete(array.get(bullBreakerBoxes, i))
            array.remove(bullBreakerBoxes, i)
            array.remove(bullBreakerTops, i)
            array.remove(bullBreakerBots, i)

if array.size(bearBreakerBoxes) > 0
    for i = array.size(bearBreakerBoxes) - 1 to 0
        if i < array.size(bearBreakerTops) and close > array.get(bearBreakerTops, i)
            box.delete(array.get(bearBreakerBoxes, i))
            array.remove(bearBreakerBoxes, i)
            array.remove(bearBreakerTops, i)
            array.remove(bearBreakerBots, i)

// --- OB Helper Functions ---
getNearestBullOBBottom() =>
    result = close - (atrValue * atrMult)
    if array.size(bullOBBottoms) > 0
        nearestDist = 999999.0
        for i = 0 to array.size(bullOBBottoms) - 1
            obBot = array.get(bullOBBottoms, i)
            obTop = array.get(bullOBTops, i)
            // FIX: Usar ATR para proximidad en vez de % fijo (gold se mueve mucho)
            obProximity = atrValue * 0.5  // Dentro del OB o hasta 0.5 ATR por encima
            if close >= obBot and close <= obTop + obProximity
                dist = math.abs(close - obBot)
                if dist < nearestDist
                    nearestDist := dist
                    result := obBot
    result

getNearestBearOBTop() =>
    result = close + (atrValue * atrMult)
    if array.size(bearOBTops) > 0
        nearestDist = 999999.0
        for i = 0 to array.size(bearOBTops) - 1
            obTop = array.get(bearOBTops, i)
            obBot = array.get(bearOBBottoms, i)
            obProximity = atrValue * 0.5
            if close <= obTop and close >= obBot - obProximity
                dist = math.abs(obTop - close)
                if dist < nearestDist
                    nearestDist := dist
                    result := obTop
    result

inBullOB() =>
    result = false
    if array.size(bullOBTops) > 0
        for i = 0 to math.min(array.size(bullOBTops) - 1, maxOB - 1)
            if low <= array.get(bullOBTops, i) and low >= array.get(bullOBBottoms, i)
                result := true
                break
    result

inBearOB() =>
    result = false
    if array.size(bearOBTops) > 0
        for i = 0 to math.min(array.size(bearOBTops) - 1, maxOB - 1)
            if high >= array.get(bearOBBottoms, i) and high <= array.get(bearOBTops, i)
                result := true
                break
    result

// Breaker Block detection
inBullBreaker() =>
    result = false
    if array.size(bullBreakerTops) > 0
        for i = 0 to math.min(array.size(bullBreakerTops) - 1, maxBreaker - 1)
            if low <= array.get(bullBreakerTops, i) and low >= array.get(bullBreakerBots, i)
                result := true
                break
    result

inBearBreaker() =>
    result = false
    if array.size(bearBreakerTops) > 0
        for i = 0 to math.min(array.size(bearBreakerTops) - 1, maxBreaker - 1)
            if high >= array.get(bearBreakerBots, i) and high <= array.get(bearBreakerTops, i)
                result := true
                break
    result

// ============================================================================
// FVG
// ============================================================================

var array<box> bullFVGBoxes     = array.new<box>()
var array<box> bearFVGBoxes     = array.new<box>()
var array<float> bullFVGTops    = array.new<float>()
var array<float> bullFVGBottoms = array.new<float>()
var array<float> bearFVGTops    = array.new<float>()
var array<float> bearFVGBottoms = array.new<float>()

fvgMinPips = close * (fvgMinSize / 100)

bullFVGCond = low > high[2] and (low - high[2]) > fvgMinPips and isBullCandle[1]
bearFVGCond = high < low[2] and (low[2] - high) > fvgMinPips and isBearCandle[1]

if showFVG and bullFVGCond and barstate.isconfirmed
    if array.size(bullFVGBoxes) >= maxFVG
        oldBox = array.shift(bullFVGBoxes)
        box.delete(oldBox)
        array.shift(bullFVGTops)
        array.shift(bullFVGBottoms)
    fvgBot = high[2]
    fvgTop = low
    newBox = box.new(bar_index - 2, fvgTop, bar_index + 30, fvgBot, bgcolor=fvgBullColor, border_color=color.new(color.blue, 50), border_width=1)
    array.push(bullFVGBoxes, newBox)
    array.push(bullFVGTops, fvgTop)
    array.push(bullFVGBottoms, fvgBot)

if showFVG and bearFVGCond and barstate.isconfirmed
    if array.size(bearFVGBoxes) >= maxFVG
        oldBox = array.shift(bearFVGBoxes)
        box.delete(oldBox)
        array.shift(bearFVGTops)
        array.shift(bearFVGBottoms)
    fvgBot = high
    fvgTop = low[2]
    newBox = box.new(bar_index - 2, fvgTop, bar_index + 30, fvgBot, bgcolor=fvgBearColor, border_color=color.new(color.orange, 50), border_width=1)
    array.push(bearFVGBoxes, newBox)
    array.push(bearFVGTops, fvgTop)
    array.push(bearFVGBottoms, fvgBot)

// Mitigar FVG
if array.size(bullFVGBoxes) > 0
    for i = array.size(bullFVGBoxes) - 1 to 0
        if i < array.size(bullFVGBottoms) and low <= array.get(bullFVGBottoms, i)
            box.delete(array.get(bullFVGBoxes, i))
            array.remove(bullFVGBoxes, i)
            array.remove(bullFVGTops, i)
            array.remove(bullFVGBottoms, i)

if array.size(bearFVGBoxes) > 0
    for i = array.size(bearFVGBoxes) - 1 to 0
        if i < array.size(bearFVGTops) and high >= array.get(bearFVGTops, i)
            box.delete(array.get(bearFVGBoxes, i))
            array.remove(bearFVGBoxes, i)
            array.remove(bearFVGTops, i)
            array.remove(bearFVGBottoms, i)

inBullFVG() =>
    result = false
    if array.size(bullFVGTops) > 0
        for i = 0 to math.min(array.size(bullFVGTops) - 1, maxFVG - 1)
            if low <= array.get(bullFVGTops, i) and low >= array.get(bullFVGBottoms, i)
                result := true
                break
    result

inBearFVG() =>
    result = false
    if array.size(bearFVGTops) > 0
        for i = 0 to math.min(array.size(bearFVGTops) - 1, maxFVG - 1)
            if high >= array.get(bearFVGBottoms, i) and high <= array.get(bearFVGTops, i)
                result := true
                break
    result

// ============================================================================
// INDUCEMENT (SMC LuxAlgo concept)
// Liquidez interna: minor swing highs/lows que actúan como trampa
// ============================================================================

var float lastInducementHigh = na
var float lastInducementLow = na

minorSwingH = ta.pivothigh(high, 3, 3)
minorSwingL = ta.pivotlow(low, 3, 3)

if not na(minorSwingH) and not na(lastSH) and minorSwingH < lastSH
    lastInducementHigh := minorSwingH

if not na(minorSwingL) and not na(lastSL) and minorSwingL > lastSL
    lastInducementLow := minorSwingL

inducementSweptHigh = not na(lastInducementHigh) and high > lastInducementHigh and close < lastInducementHigh
inducementSweptLow  = not na(lastInducementLow) and low < lastInducementLow and close > lastInducementLow

if showInducement and inducementSweptHigh and barstate.isconfirmed
    label.new(bar_index, high, "IDM", style=label.style_label_down, color=color.new(color.purple, 20), textcolor=color.white, size=size.tiny, tooltip="Inducement barrido - posible SHORT")
    lastInducementHigh := na

if showInducement and inducementSweptLow and barstate.isconfirmed
    label.new(bar_index, low, "IDM", style=label.style_label_up, color=color.new(color.purple, 20), textcolor=color.white, size=size.tiny, tooltip="Inducement barrido - posible LONG")
    lastInducementLow := na

// ============================================================================
// LIQUIDEZ
// ============================================================================

highestHigh = ta.highest(high[1], eqhLookback)
lowestLow   = ta.lowest(low[1], eqhLookback)

liqSweepHighRaw = high > highestHigh and close < open and upperWick > bodySize
liqSweepLowRaw  = low < lowestLow and close > open and lowerWick > bodySize

liqSweepHigh = filterSweeps ? (liqSweepHighRaw and inAnyKZ) : liqSweepHighRaw
liqSweepLow  = filterSweeps ? (liqSweepLowRaw and inAnyKZ) : liqSweepLowRaw

showSweepHLabel = showSweeps and liqSweepHigh and barstate.isconfirmed
showSweepLLabel = showSweeps and liqSweepLow and barstate.isconfirmed

if showSweepHLabel
    label.new(bar_index, high, "SW", style=label.style_label_down, color=color.new(bearColor, 20), textcolor=color.white, size=size.tiny)

if showSweepLLabel
    label.new(bar_index, low, "SW", style=label.style_label_up, color=color.new(bullColor, 20), textcolor=color.white, size=size.tiny)

// Equal H/L
equalHighs() =>
    threshold = close * 0.0003
    count = 0
    for i = 1 to eqhLookback
        if math.abs(high - high[i]) < threshold
            count += 1
    count >= 3

equalLows() =>
    threshold = close * 0.0003
    count = 0
    for i = 1 to eqhLookback
        if math.abs(low - low[i]) < threshold
            count += 1
    count >= 3

hasEqHighs = equalHighs()
hasEqLows  = equalLows()

if showEQHL and hasEqHighs and barstate.isconfirmed
    line.new(bar_index - eqhLookback, high, bar_index, high, color=color.new(color.purple, 50), style=line.style_dotted, width=1)
if showEQHL and hasEqLows and barstate.isconfirmed
    line.new(bar_index - eqhLookback, low, bar_index, low, color=color.new(color.purple, 50), style=line.style_dotted, width=1)

// ============================================================================
// FIBONACCI / PREMIUM-DISCOUNT ZONES (SMC LuxAlgo style)
// ============================================================================

fibHigh  = ta.highest(high, fibLookback)
fibLow   = ta.lowest(low, fibLookback)
fibRange = fibHigh - fibLow
fib500   = fibHigh - fibRange * 0.500
fib618   = fibHigh - fibRange * 0.618
fib382   = fibHigh - fibRange * 0.382
fib236   = fibHigh - fibRange * 0.236
fib786   = fibHigh - fibRange * 0.786

inDiscount     = close < fib500
inPremium      = close > fib500
inDeepDiscount = close < fib786   // Por debajo del 78.6% = deep discount
inDeepPremium  = close > fib236   // Por encima del 23.6% = deep premium

var line fib500Line = na
var line fib618Line = na
var line fib382Line = na
var line fib786Line = na
var line fib236Line = na
if showFib and barstate.islast
    line.delete(fib500Line)
    line.delete(fib618Line)
    line.delete(fib382Line)
    line.delete(fib786Line)
    line.delete(fib236Line)
    fib500Line := line.new(bar_index - fibLookback, fib500, bar_index + 5, fib500, color=color.new(color.white, 40), style=line.style_dashed, width=1)
    if showPDLevels
        fib382Line := line.new(bar_index - fibLookback, fib382, bar_index + 5, fib382, color=color.new(color.red, 60), style=line.style_dotted, width=1)
        fib618Line := line.new(bar_index - fibLookback, fib618, bar_index + 5, fib618, color=color.new(color.green, 60), style=line.style_dotted, width=1)
        fib236Line := line.new(bar_index - fibLookback, fib236, bar_index + 5, fib236, color=color.new(color.red, 70), style=line.style_dotted, width=1)
        fib786Line := line.new(bar_index - fibLookback, fib786, bar_index + 5, fib786, color=color.new(color.green, 70), style=line.style_dotted, width=1)

// v7.1 FIX: Premium/Discount como lineas Fib, NO como bgcolor solido
// El bgcolor con transparency 0 tapaba todo el chart
// Ahora: solo tiny bar highlight en bottom, no full bgcolor
// Deep zones: transparencia 96, normal zones: 98
pdBgColor = showPDLevels ? (inDeepDiscount ? color.new(color.rgb(50, 255, 50), 96) : inDiscount ? color.new(color.rgb(50, 200, 50), 98) : inDeepPremium ? color.new(color.rgb(255, 50, 50), 96) : inPremium ? color.new(color.rgb(200, 50, 50), 98) : na) : na
bgcolor(pdBgColor)

zonaName = inDeepDiscount ? "DEEP DISC." : inDiscount ? "DISCOUNT" : inDeepPremium ? "DEEP PREM." : "PREMIUM"

// ============================================================================
// PATRONES DE VELA
// ============================================================================

bullRejection    = lowerWick > bodySize * 1.5 and lowerWick > upperWick * 2 and bodySize > 0
bearRejection    = upperWick > bodySize * 1.5 and upperWick > lowerWick * 2 and bodySize > 0
bullEngulfing    = isBullCandle and isBearCandle[1] and close > open[1] and open <= close[1]
bearEngulfing    = isBearCandle and isBullCandle[1] and close < open[1] and open >= close[1]
bullContinuation = close > high[1] or bullEngulfing
bearContinuation = close < low[1] or bearEngulfing

// ============================================================================
// SISTEMA DE CONFLUENCIAS v7 - 13 FACTORES (RSI CORREGIDO + VOLUMEN + BREAKER)
// ============================================================================
// 
// v6 BUG: RSI confluencia #9 sumaba +1 cuando RSI estaba entre 30-70
//          = CASI SIEMPRE = confluencia gratis = señales basura con 3/10
//
// v7 FIX: RSI solo suma +1 cuando CONFIRMA la direccion:
//   - LONG: RSI < 40 (oversold/neutral bajo) o RSI cruzando arriba
//   - SHORT: RSI > 60 (overbought/neutral alto) o RSI cruzando abajo
//
// NUEVAS confluencias:
//   #11: Volume Confirmation (alto volumen + delta en dirección)
//   #12: VWAP Position (precio en lado correcto del VWAP)
//   #13: Breaker Block (soporte/resistencia institucional)
// ============================================================================

isInBullOB     = inBullOB()
isInBearOB     = inBearOB()
isInBullFVG    = inBullFVG()
isInBearFVG    = inBearFVG()
isInBullBrk    = inBullBreaker()
isInBearBrk    = inBearBreaker()

// --- RSI CORREGIDO ---
// LONG: RSI confirma potencial alcista
rsiConfLong  = useRSIConf and (rsiValue < 40 or (rsiValue > rsiValue[1] and rsiValue[1] < 50))
// SHORT: RSI confirma potencial bajista
rsiConfShort = useRSIConf and (rsiValue > 60 or (rsiValue < rsiValue[1] and rsiValue[1] > 50))

// --- Confluencias LONG (max 13) ---
confLong = 0
confLong := confLong + (trendUp ? 1 : 0)                                           // 1. EMA trend corto
confLong := confLong + (htfTrendUp ? 1 : 0)                                         // 2. EMA 200 trend
confLong := confLong + (isInBullOB ? 1 : 0)                                         // 3. Order Block
confLong := confLong + (inDiscount ? 1 : 0)                                         // 4. Zona Discount
confLong := confLong + (bullRejection or bullEngulfing ? 1 : 0)                     // 5. Patron vela
confLong := confLong + (liqSweepLowRaw[1] or liqSweepLowRaw[2] ? 1 : 0)            // 6. Sweep (FIX: usar RAW, no filtrado por KZ)
confLong := confLong + (choch_bull_conf[1] or choch_bull_conf[2] or bos_bull_conf[1] ? 1 : 0)  // 7. Estructura (FIX: no depende de display toggle)
confLong := confLong + (useFVGConf and isInBullFVG ? 1 : 0)                         // 8. FVG
confLong := confLong + (rsiConfLong ? 1 : 0)                                        // 9. RSI (CORREGIDO)
confLong := confLong + (useMTFConf and mtfTrendUp ? 1 : 0)                          // 10. MTF Trend
confLong := confLong + (useVolConf and bullVolConf ? 1 : 0)                          // 11. Volume (NUEVO)
confLong := confLong + (useVWAPConf and priceBelowVwap ? 1 : 0)                     // 12. VWAP position (FIX: toggle propio)
confLong := confLong + (showBreakerOB and isInBullBrk ? 1 : 0)                      // 13. Breaker Block (NUEVO)

// --- Confluencias SHORT (max 13) ---
confShort = 0
confShort := confShort + (trendDown ? 1 : 0)                                        // 1. EMA trend corto
confShort := confShort + (htfTrendDn ? 1 : 0)                                       // 2. EMA 200 trend
confShort := confShort + (isInBearOB ? 1 : 0)                                       // 3. Order Block
confShort := confShort + (inPremium ? 1 : 0)                                        // 4. Zona Premium
confShort := confShort + (bearRejection or bearEngulfing ? 1 : 0)                   // 5. Patron vela
confShort := confShort + (liqSweepHighRaw[1] or liqSweepHighRaw[2] ? 1 : 0)        // 6. Sweep (FIX: usar RAW)
confShort := confShort + (choch_bear_conf[1] or choch_bear_conf[2] or bos_bear_conf[1] ? 1 : 0)  // 7. Estructura (FIX: no depende de display toggle)
confShort := confShort + (useFVGConf and isInBearFVG ? 1 : 0)                       // 8. FVG
confShort := confShort + (rsiConfShort ? 1 : 0)                                     // 9. RSI (CORREGIDO)
confShort := confShort + (useMTFConf and mtfTrendDn ? 1 : 0)                        // 10. MTF Trend
confShort := confShort + (useVolConf and bearVolConf ? 1 : 0)                       // 11. Volume (NUEVO)
confShort := confShort + (useVWAPConf and priceAboveVwap ? 1 : 0)                   // 12. VWAP position (FIX: toggle propio)
confShort := confShort + (showBreakerOB and isInBearBrk ? 1 : 0)                    // 13. Breaker Block (NUEVO)

trendName = trendUp and htfTrendUp ? "BULL" : trendDown and htfTrendDn ? "BEAR" : "MIX"

// ============================================================================
// QUALITY SCORE (0-3)
// 0 = Basic, 1 = Normal, 2 = Strong, 3 = Premium
// ============================================================================

qualityLong = 0
qualityLong := qualityLong + (isStrongBull ? 1 : 0)
qualityLong := qualityLong + (isHighVol ? 1 : 0)
qualityLong := qualityLong + (inAnyKZ ? 1 : 0)

qualityShort = 0
qualityShort := qualityShort + (isStrongBear ? 1 : 0)
qualityShort := qualityShort + (isHighVol ? 1 : 0)
qualityShort := qualityShort + (inAnyKZ ? 1 : 0)

qualityNameLong  = qualityLong >= 3 ? "⭐PREMIUM" : qualityLong >= 2 ? "⚡STRONG" : qualityLong >= 1 ? "✓NORMAL" : "○BASIC"
qualityNameShort = qualityShort >= 3 ? "⭐PREMIUM" : qualityShort >= 2 ? "⚡STRONG" : qualityShort >= 1 ? "✓NORMAL" : "○BASIC"

// ============================================================================
// SENALES v7 - CON FILTROS MEJORADOS
// ============================================================================

kzFilter = onlyTradeKZ ? inAnyKZ : true

// CRITICO v7: Bloquear señales contra MTF dominante
// FIX: Solo bloquear cuando MTF es CLARAMENTE opuesto (no MIX)
mtfFilterLong  = requireMTFalign ? (not mtfTrendDn) : true   // Bloquea LONG solo si MTF es BEAR
mtfFilterShort = requireMTFalign ? (not mtfTrendUp) : true   // Bloquea SHORT solo si MTF es BULL

// Quality filter
qualityFilterLong  = qualityLong >= minQualityScore
qualityFilterShort = qualityShort >= minQualityScore

longCondition  = confLong >= minConfluence and bullContinuation and kzFilter and mtfFilterLong and qualityFilterLong and barstate.isconfirmed
shortCondition = confShort >= minConfluence and bearContinuation and kzFilter and mtfFilterShort and qualityFilterShort and barstate.isconfirmed

var bool lastSignalLong  = false
var bool lastSignalShort = false
var int lastSignalBar    = 0

// Reset flags on structure change
if choch_bull or choch_bear
    lastSignalLong := false
    lastSignalShort := false

// v7: Cooldown mejorado (20 barras por defecto vs 10 en v6)
longSignal  = longCondition and not lastSignalLong and (bar_index - lastSignalBar > cooldownBars)
shortSignal = shortCondition and not lastSignalShort and (bar_index - lastSignalBar > cooldownBars)

if longSignal
    lastSignalLong := true
    lastSignalShort := false
    lastSignalBar := bar_index

if shortSignal
    lastSignalShort := true
    lastSignalLong := false
    lastSignalBar := bar_index

// ============================================================================
// VISUALIZACION
// ============================================================================

plot(emaFast, "EMA 9", color=bullColor, linewidth=2)
plot(emaSlow, "EMA 21", color=bearColor, linewidth=2)
plot(showEMA200 ? ema200 : na, "EMA 200", color=color.new(color.white, 60), linewidth=1)
plot(showMTFEmas ? mtfEmaFast : na, "MTF EMA Fast", color=color.new(color.yellow, 40), linewidth=1, style=plot.style_stepline)
plot(showMTFEmas ? mtfEmaSlow : na, "MTF EMA Slow", color=color.new(color.orange, 40), linewidth=1, style=plot.style_stepline)

// VWAP Session - v7.1: linea fina para no tapar velas
plot(showVolProfile ? sessionVwap : na, "Session VWAP", color=color.new(vwapColor, 30), linewidth=1, style=plot.style_line)
plot(showVolProfile ? vwapUpper : na, "VWAP Upper", color=color.new(vwapColor, 70), linewidth=1, style=plot.style_circles)
plot(showVolProfile ? vwapLower : na, "VWAP Lower", color=color.new(vwapColor, 70), linewidth=1, style=plot.style_circles)

// Senales con color por calidad
longColor  = qualityLong >= 3 ? color.rgb(0, 255, 180) : qualityLong >= 2 ? color.rgb(0, 230, 118) : color.rgb(100, 200, 100)
shortColor = qualityShort >= 3 ? color.rgb(255, 30, 30) : qualityShort >= 2 ? color.rgb(255, 82, 82) : color.rgb(200, 100, 100)

plotshape(showSignals and longSignal, title="LONG", style=shape.triangleup, location=location.belowbar, color=longColor, size=size.normal)
plotshape(showSignals and shortSignal, title="SHORT", style=shape.triangledown, location=location.abovebar, color=shortColor, size=size.normal)

// --- Volume histogram en barras (inspirado Range Volume) ---
barcolor(isHighVol and isBullCandle ? color.new(bullColor, 20) : isHighVol and isBearCandle ? color.new(bearColor, 20) : na)

// Labels con SL/TP + Quality Score + Volume
if showSignals and showLabels and longSignal
    slBase = useOBforSL ? getNearestBullOBBottom() : close - (atrValue * atrMult)
    slPrice = slBase - totalSpreadBuf
    riskAmt = close - slPrice
    tpPrice = close + (riskAmt * rrRatio)
    slDollars = close - slPrice
    tpDollars = tpPrice - close
    slType = "ATR"
    if useOBforSL
        atrFallback = close - (atrValue * atrMult)
        if math.abs(slBase - atrFallback) > 0.01  // OB was found (different from ATR fallback)
            slType := "OB"
    fvgTxt = isInBullFVG ? " +FVG" : ""
    brkTxt = isInBullBrk ? " +BRK" : ""
    volTxt = bullVolConf ? " +VOL" : ""
    bePrice = close + riskAmt
    
    label.new(bar_index, low, 
      "LONG " + str.tostring(confLong) + "/13 " + qualityNameLong + fvgTxt + brkTxt + volTxt + "\n" +
      "SL[" + slType + "]: " + str.tostring(slPrice, "#.##") + " ($" + str.tostring(slDollars, "#.#") + ")\n" +
      "BE: " + str.tostring(bePrice, "#.##") + " ($" + str.tostring(riskAmt, "#.#") + ")\n" +
      "TP: " + str.tostring(tpPrice, "#.##") + " ($" + str.tostring(tpDollars, "#.#") + ")", 
      style=label.style_label_up, color=qualityLong >= 3 ? color.new(color.rgb(0, 255, 180), 0) : qualityLong >= 2 ? color.new(bullColor, 0) : color.new(bullColor, 30), textcolor=color.white, size=size.small)
    
    if showBELevels
        line.new(bar_index, bePrice, bar_index + beLevelExtend, bePrice, color=color.new(color.yellow, 30), style=line.style_dashed, width=1)
        label.new(bar_index + beLevelExtend, bePrice, "BE 1:1", color=color.new(color.yellow, 60), textcolor=color.white, size=size.tiny, style=label.style_label_left)
        line.new(bar_index, slPrice, bar_index + beLevelExtend, slPrice, color=color.new(bearColor, 30), style=line.style_dashed, width=1)
        line.new(bar_index, tpPrice, bar_index + beLevelExtend, tpPrice, color=color.new(bullColor, 30), style=line.style_dashed, width=1)
    if showTP2Level
        tp2Price = close + (riskAmt * 1.0)  // FIX: TP2 parcial al 1:1 (distinto de BE visual)
        line.new(bar_index, tp2Price, bar_index + beLevelExtend, tp2Price, color=color.new(color.aqua, 40), style=line.style_dotted, width=1)
        label.new(bar_index + beLevelExtend, tp2Price, "TP1 1:1", color=color.new(color.aqua, 60), textcolor=color.white, size=size.tiny, style=label.style_label_left)

if showSignals and showLabels and shortSignal
    slBase = useOBforSL ? getNearestBearOBTop() : close + (atrValue * atrMult)
    slPrice = slBase + totalSpreadBuf
    riskAmt = slPrice - close
    tpPrice = close - (riskAmt * rrRatio)
    slDollars = slPrice - close
    tpDollars = close - tpPrice
    slType = "ATR"
    if useOBforSL
        atrFallback = close + (atrValue * atrMult)
        if math.abs(slBase - atrFallback) > 0.01
            slType := "OB"
    fvgTxt = isInBearFVG ? " +FVG" : ""
    brkTxt = isInBearBrk ? " +BRK" : ""
    volTxt = bearVolConf ? " +VOL" : ""
    bePrice = close - riskAmt
    
    label.new(bar_index, high, 
      "SHORT " + str.tostring(confShort) + "/13 " + qualityNameShort + fvgTxt + brkTxt + volTxt + "\n" +
      "SL[" + slType + "]: " + str.tostring(slPrice, "#.##") + " ($" + str.tostring(slDollars, "#.#") + ")\n" +
      "BE: " + str.tostring(bePrice, "#.##") + " ($" + str.tostring(riskAmt, "#.#") + ")\n" +
      "TP: " + str.tostring(tpPrice, "#.##") + " ($" + str.tostring(tpDollars, "#.#") + ")", 
      style=label.style_label_down, color=qualityShort >= 3 ? color.new(color.rgb(255, 30, 30), 0) : qualityShort >= 2 ? color.new(bearColor, 0) : color.new(bearColor, 30), textcolor=color.white, size=size.small)
    
    if showBELevels
        line.new(bar_index, bePrice, bar_index + beLevelExtend, bePrice, color=color.new(color.yellow, 30), style=line.style_dashed, width=1)
        label.new(bar_index + beLevelExtend, bePrice, "BE 1:1", color=color.new(color.yellow, 60), textcolor=color.white, size=size.tiny, style=label.style_label_left)
        line.new(bar_index, slPrice, bar_index + beLevelExtend, slPrice, color=color.new(bearColor, 30), style=line.style_dashed, width=1)
        line.new(bar_index, tpPrice, bar_index + beLevelExtend, tpPrice, color=color.new(bullColor, 30), style=line.style_dashed, width=1)
    if showTP2Level
        tp2Price = close - (riskAmt * 1.0)  // FIX: TP2 parcial al 1:1
        line.new(bar_index, tp2Price, bar_index + beLevelExtend, tp2Price, color=color.new(color.aqua, 40), style=line.style_dotted, width=1)
        label.new(bar_index + beLevelExtend, tp2Price, "TP1 1:1", color=color.new(color.aqua, 60), textcolor=color.white, size=size.tiny, style=label.style_label_left)

// ============================================================================
// PANEL INFORMATIVO v7 - EXPANDIDO
// ============================================================================

var table panel = table.new(position.top_right, 2, 24, bgcolor=color.new(color.black, 85), border_width=1, border_color=color.gray)

if showPanel and barstate.islast
    trendTxt = trendUp and htfTrendUp ? "BULL" : trendDown and htfTrendDn ? "BEAR" : "MIX"
    trendCol = trendUp and htfTrendUp ? bullColor : trendDown and htfTrendDn ? bearColor : color.yellow
    kzTxt = inLondonKZ ? "LONDON" : inNYOverlap ? "NY-OVL" : inNYKZ ? "NY" : inTokyoKZ ? "TKY" : "-"
    kzCol = inAnyKZ ? color.lime : color.gray
    zonaTxt = zonaName
    zonaCol = inDiscount ? bullColor : bearColor
    fvgTxt = isInBullFVG ? "BULL" : isInBearFVG ? "BEAR" : "-"
    fvgCol = isInBullFVG ? color.rgb(0, 150, 255) : isInBearFVG ? color.rgb(255, 150, 0) : color.gray
    
    table.cell(panel, 0, 0, "SMS-XAU v7", text_color=color.rgb(255, 215, 0), text_size=size.small)
    table.cell(panel, 1, 0, "PRO", text_color=color.rgb(0, 150, 255), text_size=size.small)
    
    table.cell(panel, 0, 1, "Trend", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 1, 1, trendTxt, text_color=trendCol, text_size=size.tiny)
    
    mtfCol = mtfTrendUp ? bullColor : mtfTrendDn ? bearColor : color.yellow
    table.cell(panel, 0, 2, "MTF " + mtfTF, text_color=color.white, text_size=size.tiny)
    table.cell(panel, 1, 2, mtfTrendName, text_color=mtfCol, text_size=size.tiny)
    
    table.cell(panel, 0, 3, "KZ", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 1, 3, kzTxt, text_color=kzCol, text_size=size.tiny)
    
    table.cell(panel, 0, 4, "Zona", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 1, 4, zonaTxt, text_color=zonaCol, text_size=size.tiny)
    
    table.cell(panel, 0, 5, "ATR", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 1, 5, "$" + str.tostring(atrValue, "#.#"), text_color=color.orange, text_size=size.tiny)
    
    table.cell(panel, 0, 6, "OB", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 1, 6, isInBullOB ? "BULL" : isInBearOB ? "BEAR" : "-", text_color=isInBullOB ? bullColor : isInBearOB ? bearColor : color.gray, text_size=size.tiny)
    
    table.cell(panel, 0, 7, "FVG", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 1, 7, fvgTxt, text_color=fvgCol, text_size=size.tiny)
    
    // Breaker Block
    brkTxt = isInBullBrk ? "BULL" : isInBearBrk ? "BEAR" : "-"
    brkCol = isInBullBrk ? color.rgb(0, 200, 255) : isInBearBrk ? color.rgb(255, 100, 200) : color.gray
    table.cell(panel, 0, 8, "Breaker", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 1, 8, brkTxt, text_color=brkCol, text_size=size.tiny)
    
    rsiTxt = rsiValue < rsiOS ? "OVERSOLD" : rsiValue > rsiOB ? "OVERBOUGHT" : str.tostring(rsiValue, "#.0")
    rsiCol = rsiValue < rsiOS ? bullColor : rsiValue > rsiOB ? bearColor : color.white
    table.cell(panel, 0, 9, "RSI", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 1, 9, rsiTxt, text_color=rsiCol, text_size=size.tiny)
    
    // Volume
    volTxt = isHighVol ? "HIGH (" + str.tostring(volRatio, "#.#") + "x)" : isLowVol ? "LOW" : str.tostring(volRatio, "#.#") + "x"
    volCol = isHighVol ? color.lime : isLowVol ? color.gray : color.white
    table.cell(panel, 0, 10, "Volume", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 1, 10, volTxt, text_color=volCol, text_size=size.tiny)
    
    // VWAP
    vwapPosTxt = priceAboveVwap ? "ABOVE" : priceBelowVwap ? "BELOW" : "AT"
    vwapPosCol = priceAboveVwap ? bearColor : priceBelowVwap ? bullColor : color.yellow
    table.cell(panel, 0, 11, "VWAP", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 1, 11, vwapPosTxt, text_color=vwapPosCol, text_size=size.tiny)
    
    table.cell(panel, 0, 12, "L-Conf", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 1, 12, str.tostring(confLong) + "/13", text_color=confLong >= minConfluence ? bullColor : color.gray, text_size=size.tiny)
    
    table.cell(panel, 0, 13, "S-Conf", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 1, 13, str.tostring(confShort) + "/13", text_color=confShort >= minConfluence ? bearColor : color.gray, text_size=size.tiny)
    
    table.cell(panel, 0, 14, "Spread", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 1, 14, "$" + str.tostring(spreadPips, "#.#"), text_color=color.orange, text_size=size.tiny)
    
    table.cell(panel, 0, 15, "SL Mode", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 1, 15, useOBforSL ? "OB+Spread" : "ATR", text_color=color.aqua, text_size=size.tiny)
    
    table.cell(panel, 0, 16, "Alertas", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 1, 16, enableAlerts ? "ON" : "OFF", text_color=enableAlerts ? color.lime : color.gray, text_size=size.tiny)
    
    table.cell(panel, 0, 17, "FVG Conf", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 1, 17, useFVGConf ? "ON" : "OFF", text_color=useFVGConf ? color.lime : color.gray, text_size=size.tiny)
    
    table.cell(panel, 0, 18, "RSI Conf", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 1, 18, useRSIConf ? "ON (FIX)" : "OFF", text_color=useRSIConf ? color.lime : color.gray, text_size=size.tiny)
    
    table.cell(panel, 0, 19, "MTF Conf", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 1, 19, useMTFConf ? "ON (" + mtfTF + ")" : "OFF", text_color=useMTFConf ? color.lime : color.gray, text_size=size.tiny)
    
    table.cell(panel, 0, 20, "Vol Conf", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 1, 20, useVolConf ? "ON" : "OFF", text_color=useVolConf ? color.lime : color.gray, text_size=size.tiny)
    
    // MTF Align lock
    mtfLockTxt = requireMTFalign ? "LOCKED" : "FREE"
    mtfLockCol = requireMTFalign ? color.rgb(255, 215, 0) : color.gray
    table.cell(panel, 0, 21, "MTF Lock", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 1, 21, mtfLockTxt, text_color=mtfLockCol, text_size=size.tiny)
    
    // Momentum & Quality
    momTxt = isStrongBull ? "⚡BULL" : isStrongBear ? "⚡BEAR" : isMomCandle ? "ACTIVE" : "-"
    momCol = isStrongBull ? bullColor : isStrongBear ? bearColor : isMomCandle ? color.yellow : color.gray
    table.cell(panel, 0, 22, "Momentum", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 1, 22, momTxt, text_color=momCol, text_size=size.tiny)
    
    table.cell(panel, 0, 23, "BE Level", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 1, 23, showBELevels ? "ON" : "OFF", text_color=showBELevels ? color.lime : color.gray, text_size=size.tiny)

// ============================================================================
// ALERTAS v7 - MEJORADAS: FILTROS DE CALIDAD
// ============================================================================

slLongCalc  = useOBforSL ? getNearestBullOBBottom() - totalSpreadBuf : close - (atrValue * atrMult) - totalSpreadBuf
tpLongCalc  = close + ((close - slLongCalc) * rrRatio)
slShortCalc = useOBforSL ? getNearestBearOBTop() + totalSpreadBuf : close + (atrValue * atrMult) + totalSpreadBuf
tpShortCalc = close - ((slShortCalc - close) * rrRatio)

slLongDollars  = close - slLongCalc
tpLongDollars  = tpLongCalc - close
slShortDollars = slShortCalc - close
tpShortDollars = close - tpShortCalc

beLongCalc  = close + (close - slLongCalc)
beShortCalc = close - (slShortCalc - close)

fvgLongTxt  = isInBullFVG ? "✅" : "❌"
fvgShortTxt = isInBearFVG ? "✅" : "❌"
volLongTxt  = bullVolConf ? "✅HIGH" : "◯"
volShortTxt = bearVolConf ? "✅HIGH" : "◯"

longMessage = "🟢 LONG XAUUSD v7\n" +
     "━━━━━━━━━━━━━━━\n" +
     "📍 Entrada: " + str.tostring(close, "#.##") + "\n" +
     "🛑 SL: " + str.tostring(slLongCalc, "#.##") + " ($" + str.tostring(slLongDollars, "#.#") + ")\n" +
     "🔰 BE 1:1: " + str.tostring(beLongCalc, "#.##") + "\n" +
     "🎯 TP: " + str.tostring(tpLongCalc, "#.##") + " ($" + str.tostring(tpLongDollars, "#.#") + ")\n" +
     "━━━━━━━━━━━━━━━\n" +
     "📊 Confluencias: " + str.tostring(confLong) + "/13\n" +
     "🏆 Calidad: " + qualityNameLong + "\n" +
     "📦 FVG: " + fvgLongTxt + "\n" +
     "📊 Volumen: " + volLongTxt + " (" + str.tostring(volRatio, "#.#") + "x)\n" +
     "📉 RSI: " + str.tostring(rsiValue, "#.0") + "\n" +
     "⏰ Kill Zone: " + kzName + "\n" +
     "📈 Tendencia: " + trendName + "\n" +
     "🔄 MTF " + mtfTF + ": " + mtfTrendName + "\n" +
     "🎚️ Zona: " + zonaName + "\n" +
     "📐 ATR: $" + str.tostring(atrValue, "#.#") + "\n" +
     "📏 VWAP: " + str.tostring(sessionVwap, "#.##")

shortMessage = "🔴 SHORT XAUUSD v7\n" +
     "━━━━━━━━━━━━━━━\n" +
     "📍 Entrada: " + str.tostring(close, "#.##") + "\n" +
     "🛑 SL: " + str.tostring(slShortCalc, "#.##") + " ($" + str.tostring(slShortDollars, "#.#") + ")\n" +
     "🔰 BE 1:1: " + str.tostring(beShortCalc, "#.##") + "\n" +
     "🎯 TP: " + str.tostring(tpShortCalc, "#.##") + " ($" + str.tostring(tpShortDollars, "#.#") + ")\n" +
     "━━━━━━━━━━━━━━━\n" +
     "📊 Confluencias: " + str.tostring(confShort) + "/13\n" +
     "🏆 Calidad: " + qualityNameShort + "\n" +
     "📦 FVG: " + fvgShortTxt + "\n" +
     "📊 Volumen: " + volShortTxt + " (" + str.tostring(volRatio, "#.#") + "x)\n" +
     "📉 RSI: " + str.tostring(rsiValue, "#.0") + "\n" +
     "⏰ Kill Zone: " + kzName + "\n" +
     "📈 Tendencia: " + trendName + "\n" +
     "🔄 MTF " + mtfTF + ": " + mtfTrendName + "\n" +
     "🎚️ Zona: " + zonaName + "\n" +
     "📐 ATR: $" + str.tostring(atrValue, "#.#") + "\n" +
     "📏 VWAP: " + str.tostring(sessionVwap, "#.##")

// --- Alertas con filtros de calidad ---
alertConfLong  = confLong >= alertMinConf
alertConfShort = confShort >= alertMinConf
alertKZFilter  = alertOnlyKZ ? inAnyKZ : true
alertQualLong  = alertOnlyStrong ? qualityLong >= 2 : true
alertQualShort = alertOnlyStrong ? qualityShort >= 2 : true

if enableAlerts and longSignal and alertConfLong and alertKZFilter and alertQualLong
    alert(longMessage, alert.freq_once_per_bar_close)

if enableAlerts and shortSignal and alertConfShort and alertKZFilter and alertQualShort
    alert(shortMessage, alert.freq_once_per_bar_close)

if enableAlerts and alertOnCHoCH and choch_bull_c
    alert("⚡ CHoCH ALCISTA XAUUSD @ " + str.tostring(close, "#.##") + " | KZ: " + kzName + " | Vol: " + str.tostring(volRatio, "#.#") + "x", alert.freq_once_per_bar_close)

if enableAlerts and alertOnCHoCH and choch_bear_c
    alert("⚡ CHoCH BAJISTA XAUUSD @ " + str.tostring(close, "#.##") + " | KZ: " + kzName + " | Vol: " + str.tostring(volRatio, "#.#") + "x", alert.freq_once_per_bar_close)

if enableAlerts and alertOnBOS and bos_bull_c
    alert("📈 BOS ALCISTA XAUUSD @ " + str.tostring(close, "#.##") + " | KZ: " + kzName, alert.freq_once_per_bar_close)

if enableAlerts and alertOnBOS and bos_bear_c
    alert("📉 BOS BAJISTA XAUUSD @ " + str.tostring(close, "#.##") + " | KZ: " + kzName, alert.freq_once_per_bar_close)

if enableAlerts and alertOnSweeps and showSweepHLabel
    alert("💧 SWEEP HIGHS XAUUSD @ " + str.tostring(close, "#.##") + " - Posible SHORT | KZ: " + kzName + " | Vol: " + str.tostring(volRatio, "#.#") + "x", alert.freq_once_per_bar_close)

if enableAlerts and alertOnSweeps and showSweepLLabel
    alert("💧 SWEEP LOWS XAUUSD @ " + str.tostring(close, "#.##") + " - Posible LONG | KZ: " + kzName + " | Vol: " + str.tostring(volRatio, "#.#") + "x", alert.freq_once_per_bar_close)

// ============================================================================
// ALERTCONDITIONS
// ============================================================================

alertcondition(longSignal, title="LONG Signal", message="LONG XAUUSD v7")
alertcondition(shortSignal, title="SHORT Signal", message="SHORT XAUUSD v7")
alertcondition(longSignal and qualityLong >= 2, title="LONG STRONG+", message="LONG STRONG XAUUSD v7")
alertcondition(shortSignal and qualityShort >= 2, title="SHORT STRONG+", message="SHORT STRONG XAUUSD v7")
alertcondition(longSignal and qualityLong >= 3, title="LONG PREMIUM", message="LONG PREMIUM XAUUSD v7")
alertcondition(shortSignal and qualityShort >= 3, title="SHORT PREMIUM", message="SHORT PREMIUM XAUUSD v7")
alertcondition(choch_bull_c, title="CHoCH BULL", message="CHoCH Alcista XAUUSD")
alertcondition(choch_bear_c, title="CHoCH BEAR", message="CHoCH Bajista XAUUSD")
alertcondition(bos_bull_c, title="BOS BULL", message="BOS Alcista XAUUSD")
alertcondition(bos_bear_c, title="BOS BEAR", message="BOS Bajista XAUUSD")
alertcondition(showSweepHLabel, title="SWEEP HIGH", message="Sweep Highs XAUUSD")
alertcondition(showSweepLLabel, title="SWEEP LOW", message="Sweep Lows XAUUSD")
